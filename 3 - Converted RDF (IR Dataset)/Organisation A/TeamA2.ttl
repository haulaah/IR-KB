<https://haulaah.github.io/CIRPO/incident/41144> a :Incident ;
    :hasIncidentId "41144" ;
    :hasIncidentName "Ransomware Incident - srv-web01.irorg.logical - 24 February 2026" ;
    :hasIncidentDescription "Multiple high-severity SIEM alerts indicated a ransomware attack within the irorg domain environment on 24th of February 2026. Suspicious executables and PowerShell activity were detected on ws-user03 and ws-user04 hosts. Admin credentials were used to access dc01.irorg.local and ransomware deployed on srv-web01.irorg.local. Backup infrastructure may also be compromised." ;
    :hasIncidentSeverity "3" ;
